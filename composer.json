{
    "name": "Aurora-Suite-Enterprises/pdftk",
    "description": "Aurora Suite Pdftk Library",
    "keywords": [
        "aurora-suite",
        "laravel",
        "pdftk"
    ],
    "homepage": "https://github.com/Aurora-Suite-Enterprises/pdftk",
    "license": "MIT",
    "authors": [
        {
            "name": "Cole Shirley",
            "email": "cole@aurorasuite.ca",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "mikehaertl/php-pdftk": "^0.14.3",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^11.0.0||^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AuroraSuite\\Pdftk\\": "src/",
            "AuroraSuite\\Pdftk\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AuroraSuite\\Pdftk\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AuroraSuite\\Pdftk\\PdftkServiceProvider"
            ],
            "aliases": {
                "Pdftk": "AuroraSuite\\Pdftk\\Facades\\Pdftk"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
